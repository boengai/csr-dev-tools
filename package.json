      "os": [
        "current",
        "darwin",
        "linux"
      ],
      "cpu": [
        "current",
        "arm64",
        "x64"
      ]
    }
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24.5.0"
  },
  "sideEffects": false

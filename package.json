    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-image-crop": "11.0.10",
    "reflect-metadata": "0.2.2",
    "smol-toml": "1.6.1",
    "sql-formatter": "15.7.3",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.2.2",
    "turndown": "7.2.4",
    "turndown-plugin-gfm": "1.0.2",
    "yaml": "2.8.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/js-beautify": "1.14.3",
    "@types/node": "25.5.2",
